{
	"annotations": [
		{
			"kind": "AnnotationQuery",
			"spec": {
				"builtIn": true,
				"enable": true,
				"hide": true,
				"iconColor": "rgba(0, 211, 255, 1)",
				"name": "Annotations & Alerts",
				"query": {
					"datasource": {
						"name": "-- Grafana --"
					},
					"group": "grafana",
					"kind": "DataQuery",
					"spec": {},
					"version": "v0"
				}
			}
		}
	],
	"cursorSync": "Off",
	"editable": true,
	"elements": {
		"panel-1": {
			"kind": "Panel",
			"spec": {
				"data": {
					"kind": "QueryGroup",
					"spec": {
						"queries": [
							{
								"kind": "PanelQuery",
								"spec": {
									"hidden": false,
									"query": {
										"datasource": {
											"type": "loki",
											"uid": "${loki_datasource}"
										},
										"group": "loki",
										"kind": "DataQuery",
										"spec": {
											"direction": "backward",
											"editorMode": "code",
											"expr": "{job=\"ntfy\"}\n  | json\n  | event = \"message\"\n  | topic =~ \"$topic\"\n  | line_format \"{{if eq .priority \\\"5\\\"}}🔴{{else if eq .priority \\\"4\\\"}}🟠{{else if eq .priority \\\"3\\\"}}🟡{{else if eq .priority \\\"2\\\"}}🟢{{else if eq .priority \\\"1\\\"}}⚪{{else}}🔵{{end}} [ {{.topic}} ]{{if .title}} *{{.title}}* —{{end}} {{.message}}\"",
											"queryType": "range"
										},
										"version": "v0"
									},
									"refId": "A"
								}
							}
						],
						"queryOptions": {},
						"transformations": []
					}
				},
				"description": "",
				"id": 1,
				"links": [],
				"title": "Notificaciones",
				"vizConfig": {
					"group": "logs",
					"kind": "VizConfig",
					"spec": {
						"fieldConfig": {
							"defaults": {},
							"overrides": []
						},
						"options": {
							"dedupStrategy": "none",
							"enableInfiniteScrolling": false,
							"enableLogDetails": true,
							"prettifyLogMessage": false,
							"showControls": false,
							"showFieldSelector": false,
							"showLevel": false,
							"showTime": true,
							"sortOrder": "Descending",
							"timestampResolution": "ms",
							"unwrappedColumns": false,
							"wrapLogMessage": true
						}
					},
					"version": "13.0.1"
				}
			}
		}
	},
	"layout": {
		"kind": "GridLayout",
		"spec": {
			"items": [
				{
					"kind": "GridLayoutItem",
					"spec": {
						"element": {
							"kind": "ElementReference",
							"name": "panel-1"
						},
						"height": 16,
						"width": 24,
						"x": 0,
						"y": 0
					}
				}
			]
		}
	},
	"links": [],
	"liveNow": false,
	"preferences": {
		"layout": {
			"kind": "GridLayout",
			"spec": {
				"items": []
			}
		}
	},
	"preload": false,
	"tags": ["ntfy", "notifications"],
	"timeSettings": {
		"autoRefresh": "30s",
		"autoRefreshIntervals": [
			"5s",
			"10s",
			"30s",
			"1m",
			"5m",
			"15m",
			"30m",
			"1h",
			"2h",
			"1d"
		],
		"fiscalYearStartMonth": 0,
		"from": "now-24h",
		"hideTimepicker": false,
		"timezone": "browser",
		"to": "now"
	},
	"title": "ntfy",
	"variables": [
		{
			"kind": "QueryVariable",
			"spec": {
				"allowCustomValue": true,
				"current": {
					"text": "All",
					"value": "$__all"
				},
				"definition": "",
				"hide": "dontHide",
				"includeAll": true,
				"label": "Datasource",
				"multi": false,
				"name": "loki_datasource",
				"options": [],
				"query": {
					"datasource": {
						"type": "grafana"
					},
					"group": "grafana",
					"kind": "DataQuery",
					"spec": {
						"type": "datasource",
						"pluginId": "loki"
					},
					"version": "v0"
				},
				"refresh": "onDashboardLoad",
				"regex": "",
				"skipUrlSync": false,
				"sort": "disabled"
			}
		},
		{
			"kind": "QueryVariable",
			"spec": {
				"allowCustomValue": true,
				"current": {
					"text": "All",
					"value": "$__all"
				},
				"definition": "",
				"hide": "dontHide",
				"includeAll": true,
				"label": "Topic",
				"multi": false,
				"name": "topic",
				"options": [],
				"query": {
					"datasource": {
						"type": "loki",
						"uid": "${loki_datasource}"
					},
					"group": "loki",
					"kind": "DataQuery",
					"spec": {
						"label": "topic",
						"refId": "LokiVariableQueryEditor-VariableQuery",
						"stream": "{job=\"ntfy\"}",
						"type": 1
					},
					"version": "v0"
				},
				"refresh": "onDashboardLoad",
				"regex": "",
				"regexApplyTo": "value",
				"skipUrlSync": false,
				"sort": "alphabetical_asc"
			}
		}
	]
}

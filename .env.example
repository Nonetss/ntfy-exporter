# Copiar a .env y ajustar (docker compose carga .env automáticamente).

# Obligatorias
NTFY_URL=https://ntfy.example.com
NTFY_TOPICS=topic-one,topic-two
LOKI_URL=http://host.docker.internal:3100

# Opcional: etiqueta job en Loki
# LOKI_JOB=ntfy

# Opcional: también enviar open / keepalive además de message (true/1/on)
# NTFY_EXPORT_ALL_EVENTS=

# Opcional: renderiza ASCII art del título (o primera línea del mensaje) →
#   stdout (docker compose logs) + campo figure_ascii en el JSON enviado a Loki.
# NTFY_PRINT_TITLE_FIGURE=

# Opcional: fuente de go-figure (ej. basic, doom, banner). Vacío = fuente por defecto (standard).
# NTFY_TITLE_FIGURE_FONT=

# Opcional: ancho de columnas de salida del ASCII art.
#   La frase se divide en trozos para que cada bloque renderizado ocupe ~N columnas.
#   Vacío/0 = sin división, frase limitada a 80 caracteres.
# NTFY_FIGURE_LINE_WIDTH=100

# Opcional: multi-tenant Loki
# LOKI_TENANT_ID=

# Opcional: basic auth hacia Loki
# LOKI_BASIC_AUTH_USER=
# LOKI_BASIC_AUTH_PASSWORD=

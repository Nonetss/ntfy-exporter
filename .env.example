# Copiar a .env y ajustar (docker compose carga .env automáticamente).

# Obligatorias
NTFY_URL=https://ntfy.example.com
NTFY_TOPICS=topic-one,topic-two
LOKI_URL=http://host.docker.internal:3100

# Opcional: etiqueta job en Loki
# LOKI_JOB=ntfy

# Opcional: también enviar open / keepalive además de message (true/1/on)
# NTFY_EXPORT_ALL_EVENTS=

# Opcional: multi-tenant Loki
# LOKI_TENANT_ID=

# Opcional: basic auth hacia Loki
# LOKI_BASIC_AUTH_USER=
# LOKI_BASIC_AUTH_PASSWORD=
